# GPT 剧本 / OpenAI TTS / DALL·E（可只配其一）
OPENAI_API_KEY=sk-xxx
# 多 Key 轮询（逗号、空格或换行分隔；可与 OPENAI_API_KEY 同时配置，会合并去重）
# OPENAI_API_KEYS=sk-a,sk-b,sk-c

# TTS（可选：用内部 API 时填 BASE_URL）
TTS_BASE_URL=
TTS_API_KEY=
# 或直接用 OpenAI TTS
USE_OPENAI_TTS=true

# 文生图：openai（DALL·E）| sd_webui（本地 AUTOMATIC1111，需 --api）
# DALL·E 若报 billing_hard_limit_reached：去 OpenAI 控制台加额度/换 Key，或改 IMAGE_PROVIDER=sd_webui
IMAGE_PROVIDER=openai
USE_OPENAI_IMAGE=true
# 本地 SD（IMAGE_PROVIDER=sd_webui 时生效）
SD_WEBUI_BASE_URL=http://127.0.0.1:7860
SD_STEPS=28
SD_WIDTH=512
SD_HEIGHT=768
SD_CFG_SCALE=7.0
SD_SAMPLER_NAME=DPM++ 2M Karras
# SD_NEGATIVE_PROMPT=（可选，不配则用默认）

STABILITY_API_KEY=
REPLICATE_API_TOKEN=

# 画面模式：images | cogvideox | animatediff（ComfyUI 文生视频）
VISUAL_MODE=images

# ComfyUI（VISUAL_MODE=cogvideox / animatediff）
COMFYUI_BASE_URL=http://127.0.0.1:8188

# CogVideoXWrapper
COGVIDEOX_WORKFLOW_PATH=
COGVIDEOX_PROMPT_NODE_ID=
COGVIDEOX_NEGATIVE_NODE_ID=
COGVIDEOX_RANDOMIZE_SEED=true

# AnimateDiff：Prompt → Checkpoint → AnimateDiff Loader → Sampler → Video Combine
ANIMATEDIFF_WORKFLOW_PATH=
ANIMATEDIFF_PROMPT_NODE_ID=
ANIMATEDIFF_NEGATIVE_NODE_ID=
ANIMATEDIFF_RANDOMIZE_SEED=true

# 输出目录（视频、封面、临时文件）
OUTPUT_DIR=./output
TEMP_DIR=./temp

# 应用日志（app.*：合成视频、流水线节点等）；默认 ./logs/app.log 轮转
# LOG_DIR=./logs
# LOG_FILENAME=app.log
# LOG_LEVEL=INFO
# LOG_TO_FILE=true
# LOG_TO_CONSOLE=true
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=5

# Chroma 剧情记忆（可选）
CHROMA_PERSIST_DIR=./chroma_db

# SQLite 历史库（视频墙）
# DATABASE_URL=sqlite:///./data/videos.db
RAG_ENABLED=true

# 剧本：两步生成（大纲→分镜），导演向爽点控制
SCRIPT_TWO_STEP=true
OPENAI_SCRIPT_MODEL=gpt-4o-mini
# 剧本 LLM：openai | local | openai_fallback_local（OpenAI 失败再试本地兼容接口）
# 注意：未设 SCRIPT_LLM_MODE_STRICT 时，「当前工作目录下 .env」会覆盖 shell 里同名的 SCRIPT_LLM_MODE / LOCAL_LLM_* / QWEN_*
SCRIPT_LLM_MODE=openai
# SCRIPT_LLM_MODE_STRICT=true  # true=环境变量优先（容器）；false=.env 优先（本地开发）
# AI_VIDEO_ENV_FILE=.env       # 可选：指定 .env 路径（相对路径相对进程 cwd）
# 本地 OpenAI 兼容（如 Ollama：ollama serve 后填下面）
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_LLM_MODEL=qwen:0.5b
# LOCAL_LLM_API_KEY=ollama
# LOCAL_LLM_TIMEOUT_SEC=120
# LOCAL_LLM_SCRIPT_TEMPERATURE=0.35
# LOCAL_LLM_JSON_RESPONSE=true
# LOCAL_LLM_USE_NATIVE_OLLAMA=true
# OpenAI 遇 429：同一 Key 指数退避后再换 Key
SCRIPT_OPENAI_429_MAX_RETRIES=4
SCRIPT_OPENAI_429_BASE_DELAY_SEC=2.0

# 剧本兜底：SCRIPT_LLM_MODE=openai / openai_fallback_local 时，主模型失败或解析为空可再调 QWEN_*（须配 QWEN_BASE_URL）
# SCRIPT_LLM_MODE=local 时不会使用 QWEN_*，只走 LOCAL_LLM_*
QWEN_BASE_URL=http://127.0.0.1:11434/v1
QWEN_SCRIPT_MODEL=qwen:0.5b
# QWEN_API_KEY=ollama
QWEN_TIMEOUT_SEC=180

# 流水线容错：单镜 TTS/图/视频失败时用静音或占位，仍尽量导出成片
PIPELINE_FAULT_TOLERANT=true

# 画面 Prompt 额外后缀（可选）
VISUAL_PROMPT_SUFFIX=

# FFmpeg：Ken Burns、xfade、字幕样式
FFMPEG_KEN_BURNS=true
FFMPEG_XFADE=true
FFMPEG_XFADE_DURATION=0.5
FFMPEG_FPS=24

# 封面爆款大字
COVER_PROMO_TITLE=true

# 异步队列：false=内存 asyncio；true=Celery+Redis
USE_CELERY=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# 内存队列同时处理任务数；1 = 严格逐个处理
QUEUE_MAX_CONCURRENT=1

# TTS 默认声线（未匹配到角色时）
TTS_DEFAULT_VOICE=alloy
